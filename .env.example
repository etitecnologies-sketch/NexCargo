# ===========================================
# NEXCARGO — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha
# NUNCA suba o .env pro Git!
# ===========================================

# --- SUPABASE (banco de dados) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_chave_secreta_aqui

# --- JWT (segurança de login) ---
JWT_SECRET=uma_senha_super_secreta_de_pelo_menos_32_caracteres

# --- EVOLUTION API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution_aqui

# --- OPENAI (inteligência artificial) ---
OPENAI_API_KEY=sk-sua_chave_openai_aqui

# --- CLAUDE API (inteligência artificial) ---
ANTHROPIC_API_KEY=sk-ant-sua_chave_aqui

# --- REDIS (fila de tarefas) ---
REDIS_URL=redis://localhost:6379

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development

# --- N8N ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=senha_forte_aqui
N8N_WEBHOOK_URL=http://localhost:5678
