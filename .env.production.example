# ===========================================
# NEXCARGO — PRODUÇÃO
# Preencha e renomeie para .env no servidor
# ===========================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_SECRETA

# --- DOMÍNIOS ---
NEXT_PUBLIC_APP_URL=https://app.nexcargo.com.br
APP_HOST=app.nexcargo.com.br
N8N_HOST=n8n.nexcargo.com.br
EVOLUTION_HOST=evolution.nexcargo.com.br

# --- POSTGRES (se usar externo ao Supabase) ---
POSTGRES_HOST=db.seu-projeto.supabase.co
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_forte

# --- REDIS ---
REDIS_PASSWORD=senha_redis_super_forte_123

# --- N8N ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=senha_n8n_forte_123
N8N_ENCRYPTION_KEY=chave_encriptacao_n8n_32chars_aqui

# --- EVOLUTION API (WhatsApp) ---
EVOLUTION_API_URL=https://evolution.nexcargo.com.br
EVOLUTION_API_KEY=chave_evolution_api_forte

# --- SSL (certificado gratuito Let's Encrypt) ---
SSL_EMAIL=seu@email.com

# --- APP ---
NODE_ENV=production
